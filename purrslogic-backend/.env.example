# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/purrslogic?retryWrites=true&w=majority

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=config/purrslogic-gcp-key.json
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=your_dataset
BIGQUERY_VIEW=your_view

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# App
APP_ENV=development
APP_PORT=8000
